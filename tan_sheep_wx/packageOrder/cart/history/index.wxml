<view class="container">
  <block wx:if="{{loading}}">
    <view class="empty-state">加载中...</view>
  </block>

  <block wx:elif="{{orders.length === 0}}">
    <view class="empty-state">
      <text>暂无认养记录</text>
    </view>
  </block>

  <block wx:else>
    <view class="order-list">
      <view wx:for="{{orders}}" wx:key="id" class="order-card" data-order="{{item}}" bindtap="onOrderTap">
        <view class="order-header">
          <text class="order-no">认养单号：{{item.order_no}}</text>
          <text class="order-status status-{{item.status}}">{{item.status_display}}</text>
        </view>

        <view class="order-items">
          <view wx:for="{{item.items}}" wx:for-item="subItem" wx:key="sheep_id" class="order-sub-item">
            <image class="sheep-img" src="/images/icons/function/f1.png" mode="aspectFill"></image>
            <view class="sheep-info">
              <text class="sheep-name">羊只 #{{subItem.sheep_id}}</text>
              <text class="sheep-attr">耳标：{{subItem.ear_tag || '未设置'}} | 性别：{{subItem.gender}}</text>
              <text class="sheep-price">{{subItem.priceText}}</text>
            </view>
          </view>
        </view>

        <view class="order-footer">
          <text class="order-time">{{item.created_at}}</text>
          <view class="footer-right">
            <text class="detail-link">查看详情 ></text>
            <text class="total-amount">认养费用 ¥{{item.totalAmountText}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
