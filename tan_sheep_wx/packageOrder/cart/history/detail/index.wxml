<view class="detail-page" wx:if="{{order}}">
  <view class="section">
    <view class="header-row">
      <text class="title">认养信息</text>
      <text class="status {{order.statusClass}}">{{order.status_display}}</text>
    </view>
    <view class="info-row"><text class="label">认养单号</text><text class="value">{{order.order_no}}</text></view>
    <view class="info-row"><text class="label">认养状态</text><text class="value">{{order.status_display}}</text></view>
    <view class="info-row"><text class="label">认养时间</text><text class="value">{{order.created_at}}</text></view>
    <view class="info-row"><text class="label">支付方式</text><text class="value">{{order.payment_method_display || '余额支付'}}</text></view>
    <view class="info-row"><text class="label">认养费用</text><text class="value amount">¥{{order.totalAmountText}}</text></view>
    <view class="info-row"><text class="label">联系人</text><text class="value">{{order.receiverNameText}}</text></view>
    <view class="info-row"><text class="label">联系电话</text><text class="value">{{order.receiverPhoneText}}</text></view>
    <view class="info-row"><text class="label">交付地址</text><text class="value">{{order.shippingAddressText}}</text></view>
  </view>

  <view class="section">
    <view class="header-row">
      <text class="title">认养羊只（{{order.items.length}}只）</text>
    </view>

    <view class="item-card" wx:for="{{order.items}}" wx:key="sheep_id" wx:for-item="subItem">
      <image class="item-image" src="/images/icons/function/f1.png" mode="aspectFill"></image>
      <view class="item-main">
        <text class="item-name">羊只 #{{subItem.sheep_id}}</text>
        <text class="item-attr">耳标号：{{subItem.ear_tag || '未设置'}}</text>
        <text class="item-attr">性别：{{subItem.gender || '未记录'}}</text>
        <text class="item-attr">当前体重：{{subItem.weightText}}</text>
        <text class="item-attr">健康状态：{{subItem.healthStatus}}</text>
      </view>
      <text class="item-price">{{subItem.priceText}}</text>
    </view>
  </view>

  <view class="section">
    <view class="header-row">
      <text class="title">溯源记录</text>
    </view>
    <view class="trace-copy">查看该羊只的基础档案、生长记录、饲喂记录、疫苗记录和二维码溯源信息。</view>
    <button class="trace-button" bindtap="openTrace" data-sheep-id="{{order.primarySheepId}}">查看溯源记录</button>
  </view>

  <view class="section">
    <view class="header-row">
      <text class="title">交付信息</text>
    </view>
    <view class="info-row"><text class="label">交付状态</text><text class="value">{{order.deliveryStatusText}}</text></view>
    <view class="info-row"><text class="label">交付地址</text><text class="value">{{order.shippingAddressText}}</text></view>

    <block wx:if="{{order.hasLogistics}}">
      <view class="info-row"><text class="label">物流公司</text><text class="value">{{order.logistics_company || '未填写'}}</text></view>
      <view class="info-row"><text class="label">物流单号</text><text class="value">{{order.logistics_tracking_number || '未填写'}}</text></view>
      <view class="info-row"><text class="label">发货时间</text><text class="value">{{order.shipping_date || '未记录'}}</text></view>
    </block>

    <view class="info-row" wx:if="{{order.isCompleted}}">
      <text class="label">完成时间</text>
      <text class="value">{{order.delivery_date || '未记录'}}</text>
    </view>
    <view class="delivery-hint" wx:if="{{order.deliveryHint}}">{{order.deliveryHint}}</view>
  </view>
</view>

<view class="empty" wx:else>
  <text>认养信息不存在</text>
</view>
