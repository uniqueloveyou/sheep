page {
  background: #f6f7fb;
}

.detail-page {
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 14rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.status {
  font-size: 24rpx;
  color: #888;
}

.status-adopting,
.status-paid,
.status-ready_to_ship {
  color: #30a552;
}

.status-settlement {
  color: #b35a00;
}

.status-awaiting {
  color: #1268a8;
}

.status-pending {
  color: #f59a23;
}

.status-shipping {
  color: #1677ff;
}

.status-completed {
  color: #333;
}

.status-cancelled {
  color: #999;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.info-row:last-child {
  border-bottom: 0;
}

.label {
  font-size: 25rpx;
  color: #777;
}

.value {
  font-size: 25rpx;
  color: #333;
  max-width: 65%;
  text-align: right;
}

.amount {
  color: #e64340;
  font-weight: 700;
  font-size: 30rpx;
}

.item-card {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f3f3f3;
  padding: 18rpx 0;
}

.item-card:last-child {
  border-bottom: 0;
}

.item-image {
  width: 104rpx;
  height: 104rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #222;
  font-weight: 600;
}

.item-attr {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #888;
}

.item-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: 700;
  margin-left: 10rpx;
  max-width: 190rpx;
  text-align: right;
  line-height: 1.35;
}

.trace-copy {
  font-size: 25rpx;
  color: #777;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.trace-button {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  background: #1aad19;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.trace-button::after {
  border: 0;
}

.delivery-hint {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  background: #f6fbf7;
  color: #578260;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty {
  height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}
