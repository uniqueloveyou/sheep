<view class="checkout-page">

  <view class="section">
    <view class="section-title">
      <text class="section-icon"></text>
      <text>认养联系人信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">联系人</text>
      <input class="form-input" placeholder="请输入联系人姓名" value="{{receiverName}}" bindinput="onNameInput" />
    </view>
    <view class="form-item">
      <text class="form-label">联系电话</text>
      <input class="form-input" placeholder="请输入联系电话" value="{{receiverPhone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-item form-item-addr">
      <text class="form-label">交付地址</text>
      <textarea class="form-textarea" placeholder="可现在填写，也可后续补充" value="{{shippingAddress}}" bindinput="onAddressInput" auto-height />
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text class="section-icon"></text>
      <text>认养羊只（{{checkoutItems.length}}只）</text>
    </view>
    <view class="goods-item" wx:for="{{checkoutItems}}" wx:key="cart_item_id">
      <image class="goods-img" src="{{item.sheep.image || '/images/icons/function/f1.png'}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name">滩羊 #{{item.id}}</text>
        <text class="goods-attr">{{item.gender}} {{item.weight}} kg</text>
        <text class="goods-care-fee">基础照料费 ¥{{item.dailyCareFeeText || '10.00'}}/天/只</text>
      </view>
      <view class="goods-price">¥{{item.price}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text class="section-icon"></text>
      <text>优惠券</text>
    </view>

    <view class="coupon-loading" wx:if="{{couponLoading}}">正在加载优惠券...</view>

    <block wx:elif="{{availableCoupons.length}}">
      <view class="coupon-tools" wx:if="{{selectedCouponId}}">
        <text class="coupon-tools-text">已选择 1 张优惠券</text>
        <text class="coupon-clear" bindtap="onClearCouponTap">取消选择</text>
      </view>

      <view class="coupon-card {{selectedCouponId===item.id ? 'coupon-card-active' : ''}}"
            wx:for="{{availableCoupons}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onCouponTap">
        <view class="coupon-left">
          <text class="coupon-name">{{item.name}}</text>
          <text class="coupon-rule">{{item.displayText}}</text>
        </view>
        <view class="coupon-right">
          <text class="coupon-cut">可减</text>
          <text class="coupon-money">¥{{item.previewDiscount}}</text>
          <text class="coupon-state">{{selectedCouponId===item.id ? '已选中' : '选择'}}</text>
        </view>
      </view>
    </block>

    <view class="coupon-empty" wx:else>当前认养暂无可用优惠券</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text class="section-icon"></text>
      <text>支付方式</text>
    </view>
    <view class="pay-row">
      <view class="pay-left">
        <van-icon name="gold-coin-o" color="#f39c12" size="20px" />
        <text class="pay-label">余额支付</text>
      </view>
      <text class="pay-balance">可用余额 {{balance}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text class="section-icon"></text>
      <text>认养费用明细</text>
    </view>
    <view class="amount-row">
      <text class="amount-label">认养费用</text>
      <text class="amount-value">¥{{originalTotalPrice}}</text>
    </view>
    <view class="amount-row" wx:if="{{selectedCouponId}}">
      <text class="amount-label">优惠券抵扣</text>
      <text class="amount-discount">-¥{{discountAmount}}</text>
    </view>
    <view class="amount-row amount-row-final">
      <text class="amount-label-final">应付费用</text>
      <text class="amount-payable">¥{{payableAmount}}</text>
    </view>
    <text class="coupon-tip" wx:if="{{couponTip}}">{{couponTip}}</text>
  </view>

  <view class="footer-bar">
    <view class="footer-total">
      <text class="total-label">应付：</text>
      <text class="total-price">¥{{payableAmount}}</text>
    </view>
    <van-button type="danger" round loading="{{loading}}" bind:click="submitOrder" class="submit-btn">确认认养</van-button>
  </view>

</view>
