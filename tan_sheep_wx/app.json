    "subPackages": [
        {
            "root": "pages/feature1",
            "name": "feature1",
            "pages": [
                "feature1",
                "customize/customize"
            ]
        },
        {
            "root": "pages/feature2",
            "name": "feature2",
            "pages": [
                "feature2",
                "newpage1/newpage1",
                "newpage2/newpage2",
                "newpage3/newpage3",
                "newpage4/newpage4",
                "newpage5/newpage5",
                "newpage6/newpage6"
            ]
        },
        {
            "root": "pages/feature3",
            "name": "feature3",
            "pages": [
                "feature3",
                "navigatePage/navigatePage"
            ]
        },
        {
            "root": "pages/feature4",
            "name": "feature4",
            "pages": [
                "feature4"
            ]
        },
        {
            "root": "pages/feature5",
            "name": "feature5",
            "pages": [
                "feature5",
                "grouth/grouth"
            ]
        },
        {
            "root": "pages/feature6",
            "name": "feature6",
            "pages": [
                "feature6",
                "monitor1/monitor1",
