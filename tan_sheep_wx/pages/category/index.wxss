/* category.wxss */
.view-container {
    padding: 20rpx;
}

.title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
}

.detail-item {
    margin-bottom: 10rpx;
}

.label {
    font-size: 30rpx;
    color: #666;
}

.detail-item text {
    font-size: 30rpx;
    color: #333;
}

.sheep-image {
    width: 100%;
    height: 300rpx;
    margin-top: 20rpx;
}

.adopt-button {
    background-color: #1AAD19;
    color: white;
    padding: 10rpx 20rpx;
    border: none;
    border-radius: 5rpx;
    margin-top: 20rpx;
}

.cart-button {
    background-color: #FF4500;
    color: white;
    padding: 10rpx 20rpx;
    border: none;
    border-radius: 5rpx;
    margin-top: 20rpx;
}