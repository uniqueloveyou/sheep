/* pages/qa/index.wxss */
.qa-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部标题栏 */
.qa-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #238E23;
  color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
}

.title-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 10rpx;
  font-size: 32rpx;
}

/* 消息列表容器 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  gap: 20rpx;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 用户消息右对齐 */
.message-item.user {
  flex-direction: row-reverse;
}

/* 头像 */
.message-avatar {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-avatar {
  background-color: #238E23;
  color: #fff;
}

/* 消息内容 */
.message-content {
  flex: 1;
  max-width: 70%;
}

.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
}

/* 机器人消息 */
.message-bubble.bot {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

/* 用户消息 */
.message-bubble.user {
  background-color: #238E23;
  color: #fff;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.message-detail-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-detail-card {
  padding: 16rpx;
  border-radius: 16rpx;
  background: rgba(35, 142, 35, 0.06);
}

.detail-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1b5e20;
  margin-bottom: 8rpx;
}

.detail-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
}

.related-block {
  margin-top: 16rpx;
}

.related-title {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.related-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.related-item {
  padding: 10rpx 20rpx;
  background-color: #eef7ee;
  border: 1rpx solid #b8d8b8;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #1b5e20;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.6;
  margin-top: 10rpx;
  text-align: right;
}

.message-model {
  font-size: 20rpx;
  opacity: 0.6;
  margin-top: 6rpx;
  text-align: right;
}

.message-bubble.bot .message-time {
  text-align: left;
}

.message-bubble.bot .message-model {
  text-align: left;
}

/* 快速问题 */
.quick-questions {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.quick-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.quick-item {
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

.quick-item:active {
  background-color: #238E23;
  color: #fff;
  border-color: #238E23;
}

/* 输入区域 */
.input-container {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 10rpx 20rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.send-btn {
  padding: 12rpx 30rpx;
  background-color: #ccc;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background-color: #238E23;
}

.send-icon {
  font-size: 26rpx;
}

