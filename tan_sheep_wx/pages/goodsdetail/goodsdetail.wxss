/* pages/sheepcategory/sheepcategory.wxss */
.sheep-description text {
    display: block;
    margin-top: 5px;
    font-size: 14px;
    color: #333;
}
.sheep-description-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}
.sheep-title {
    font-weight: bold;
    margin-top: 10px;
}
.sheep-price {
    align-self: flex-start;
    font-weight: bold;
    font-size: 16px;
    color: #d44d44; 
  }

.sheep-care-fee {
    font-weight: 500;
    color: #d44d44;
}

.sheep-button {
    margin-top: 15px;
    background-color: #4CAF50;
    color: white;
    border: none;
    padding: 10px 20px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    font-size: 16px;
    margin-bottom: 10px;
    cursor: pointer;
}

.sheep-action {
    display: flex;
    justify-content: space-around;
    margin-top: 10px;
}

.action-button {
    width: 45%;
    padding: 8px;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 14px;
    cursor: pointer;
}

.add-to-cart {
    background-color: #07c160;
}

.buy-now {
    background-color: #ff9900;
}
.sheep-id,
.sheep-breeder,
.sheep-phone {
    margin-top: 5px;
    font-size: 12px;
    color: #666;
}

.sheep-action {
    margin-top: 15px;
}

.sheep-swiper {
    width: 100%;
    height: 200px;
}

.sheep-swiper-item .sheep-image {
    width: 100%;
    height: 100%;
}

.swiper-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
}
.sheep-swiper {
    width: 100%;
    height: 200px;
  }
  
  .sheep-category {
    padding: 16px;
  }
  
  .sheep-swiper {
    height: 200px;
    margin-bottom: 16px;
  }
  
  .sheep-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .sheep-info {
    border: 1px solid #e5e5e5;
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 16px;
  }
  
  .sheep-description {
    margin-bottom: 16px;
  }
  
  .sheep-title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 8px;
  }
  
  .sheep-action {
    display: flex;
    justify-content: space-between;
  }
  
  .action-button {
    padding: 12px 16px;
    font-size: 16px;
    border-radius: 8px;
  }

  .add-to-cart {
    background-color: #f5a623;
    color: white;
  }

  .buy-now {
    background-color: #ff4c4c;
    color: white;
  }
