.news-detail-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.state-text {
  text-align: center;
  color: #7f8a9e;
  padding: 80rpx 0;
}

.news-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 40rpx;
  color: #1f2633;
  font-weight: 700;
  line-height: 1.45;
}

.meta {
  margin-top: 12rpx;
  color: #909cb0;
  font-size: 24rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
  background: #eef1f6;
}

.summary {
  margin-top: 20rpx;
  padding: 18rpx;
  background: #f5f9ff;
  border-radius: 10rpx;
  color: #4a5668;
  font-size: 28rpx;
  line-height: 1.7;
}

.content {
  margin-top: 24rpx;
  color: #2d3645;
  font-size: 30rpx;
  line-height: 1.95;
  white-space: pre-wrap;
  word-break: break-word;
}
