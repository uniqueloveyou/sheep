.news-list-page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 20rpx;
  box-sizing: border-box;
}

.news-item {
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.05);
}

.cover {
  width: 100%;
  height: 260rpx;
  background: #eef1f5;
}

.body {
  padding: 22rpx;
}

.title {
  font-size: 34rpx;
  color: #1f2633;
  font-weight: 700;
  line-height: 1.45;
}

.summary {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #5e6878;
  line-height: 1.7;
}

.meta-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.slot {
  font-size: 22rpx;
  color: #4a3ba0;
  background: #eee9ff;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.date {
  font-size: 24rpx;
  color: #94a0b4;
}

.state,
.empty {
  text-align: center;
  color: #93a0b3;
  padding: 30rpx 0;
  font-size: 26rpx;
}
