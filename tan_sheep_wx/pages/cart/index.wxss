.cart-container {
    padding: 16px;
}

.cart-title {
    font-size: 20px;
    margin-bottom: 16px;
}

.cart-item {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 8px;
}

.cart-checkbox {
    margin-right: 10px;
}

.cart-image {
    width: 80px;
    height: 80px;
    margin-right: 16px;
}

.cart-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.button-group {
    display: flex;
    gap: 10px;
}

.delete-button, .detail-button {
    background-color: #f56c6c;
    color: white;
    padding: 5px 10px;
    border-radius: 5px;
    font-size: 14px;
    flex-grow: 1;
    text-align: center;
}

.total-price {
    font-size: 18px;
    margin-top: 20px;
}

.checkout-button {
    margin-top: 20px;
    background-color: #4CAF50;
    color: white;
    padding: 10px;
    border-radius: 5px;
    width: 100%;
    text-align: center;
}

page {
    /* 防止 tabBar 遮挡底部内容 */
    padding-bottom: 120rpx;
}
