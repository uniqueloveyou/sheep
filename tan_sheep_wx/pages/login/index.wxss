/* ===== 全局容器 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #0f3d1a 0%, #1a6b2e 40%, #2d9e4a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 120rpx 60rpx calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* ===== 背景装饰圆 ===== */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.circle-1 {
  width: 600rpx;
  height: 600rpx;
  top: -200rpx;
  right: -180rpx;
}
.circle-2 {
  width: 400rpx;
  height: 400rpx;
  top: 300rpx;
  left: -160rpx;
}
.circle-3 {
  width: 300rpx;
  height: 300rpx;
  bottom: 200rpx;
  right: -100rpx;
}

/* ===== 品牌区 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(10rpx);
}

.logo {
  width: 110rpx;
  height: 110rpx;
}

.brand-name {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.brand-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 4rpx;
}

/* ===== 中间文字 ===== */
.hero-area {
  text-align: center;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 64rpx;
  font-weight: 900;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.hero-sub {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.6;
}

/* ===== 登录卡片 ===== */
.card {
  width: 100%;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 40rpx;
  padding: 60rpx 50rpx 50rpx;
  box-sizing: border-box;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 一键登录按钮 ===== */
.phone-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f0fff4 100%);
  color: #1a6b2e;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 0;
  letter-spacing: 2rpx;
}

.phone-btn::after {
  border: none;
}

.phone-btn:active {
  opacity: 0.88;
  transform: scale(0.97);
}

.phone-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.phone-text {
  font-size: 34rpx;
}

/* ===== 暂不登录 ===== */
.skip-btn {
  margin-top: 44rpx;
  padding: 16rpx 40rpx;
}

.skip-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.65);
}

.skip-btn:active .skip-text {
  color: #ffffff;
}

/* ===== 协议提示 ===== */
.tips {
  margin-top: 40rpx;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.8;
}

.tip-gray {
  color: rgba(255, 255, 255, 0.5);
}

.tip-link {
  color: rgba(255, 255, 255, 0.85);
  text-decoration: underline;
}
