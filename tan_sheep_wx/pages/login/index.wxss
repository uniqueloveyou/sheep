/* pages/login/index.wxss */

/* 1. 容器布局 */
.login-container {
  min-height: 100vh;
  /* 允许内容撑开高度，防止小屏手机内容被遮挡 */
  height: auto; 
  background: linear-gradient(135deg, #E8F4F8 0%, #F0F8FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  /* 增加底部安全距离适配 (iPhone X/11/12+ 等) */
  padding: 100rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 2. 头部 Logo 区域 */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(74, 144, 226, 0.8);
  letter-spacing: 2rpx;
}

/* 3. 中间内容区域 */
.login-content {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.welcome-text {
  text-align: center;
  margin-bottom: 80rpx;
}

.welcome-text .title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90E2;
  margin-bottom: 20rpx;
}

.welcome-text .subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(74, 144, 226, 0.75);
}

/* 4. 登录表单 */
.login-form {
  width: 100%;
  max-width: 600rpx;
}

.form-item {
  width: 100%;
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 30rpx;
  border-radius: 48rpx;
  background-color: #ffffff;
  font-size: 32rpx;
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #999999;
}

/* 切换登录/注册模式 */
.switch-mode {
  margin-top: 30rpx;
  text-align: center;
  padding: 20rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #4A90E2;
  text-decoration: underline;
}

.switch-mode:active {
  opacity: 0.7;
}

/* 4. 按钮区域 */
.login-buttons {
  width: 100%;
  max-width: 600rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

/* 去除微信按钮默认边框 */
.login-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #4A90E2 0%, #6BB3FF 100%);
  color: #ffffff;
}

.primary-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 5. 暂不登录（纯文字按钮） */
.cancel-login {
  margin-top: 20rpx;
  text-align: center;
  padding: 20rpx;
}

.cancel-login text {
  font-size: 28rpx;
  color: rgba(74, 144, 226, 0.7);
  text-decoration: underline; /* 加个下划线增加可点击感 */
}

.cancel-login:active {
  opacity: 0.7;
}

/* 6. 底部协议提示 */
.login-tips {
  margin-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(74, 144, 226, 0.7);
  line-height: 1.6;
}

.tip-text {
  color: rgba(74, 144, 226, 0.7);
}

.link-text {
  color: #4A90E2;
  text-decoration: underline;
  margin: 0 4rpx;
}

/* 7. 页脚 */
.login-footer {
  margin-top: 20rpx;
  text-align: center;
  padding-bottom: 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(74, 144, 226, 0.6);
  letter-spacing: 2rpx;
}