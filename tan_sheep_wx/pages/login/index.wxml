<view class="container">

  <!-- 背景装饰圆 -->
  <view class="bg-circle circle-1"></view>
  <view class="bg-circle circle-2"></view>
  <view class="bg-circle circle-3"></view>

  <!-- 顶部品牌区 -->
  <view class="brand-area">
    <view class="logo-wrap">
      <image class="logo" src="/images/icons/function/f1.png" mode="aspectFit"/>
    </view>
    <text class="brand-name">滩羊智品</text>
    <text class="brand-slogan">宁夏滩羊 · 品质溯源</text>
  </view>

  <!-- 中间插画文字 -->
  <view class="hero-area">
    <text class="hero-title">一键登录</text>
    <text class="hero-sub">使用微信手机号，安全快速完成登录</text>
  </view>

  <!-- 登录卡片 -->
  <view class="card">
    <button
      class="phone-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{loading}}"
      disabled="{{loading}}">
      <text class="phone-icon">📱</text>
      <text class="phone-text">微信手机号一键登录</text>
    </button>
    <!-- 去除按钮默认边框 -->
    <button class="phone-btn phone-btn-after" style="display:none"></button>

    <view class="skip-btn" bindtap="handleCancel">
      <text class="skip-text">暂不登录，先逛逛 →</text>
    </view>

    <view class="tips">
      <text class="tip-gray">登录即代表同意 </text>
      <text class="tip-link">《用户协议》</text>
      <text class="tip-gray"> 与 </text>
      <text class="tip-link">《隐私政策》</text>
    </view>
  </view>

</view>