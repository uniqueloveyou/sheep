<view class="login-container">
  <view class="login-header">
    <image class="logo" src="/images/icons/function/f1.png" mode="aspectFit"></image>
    <text class="app-name">滩羊智品</text>
    <text class="app-slogan">优质滩羊，品质生活</text>
  </view>

  <view class="login-content">
    <view class="welcome-text">
      <text class="title">{{isRegister ? '注册账号' : '欢迎回来'}}</text>
      <text class="subtitle">{{isRegister ? '创建新账号，开启品质生活' : '请输入用户名和密码登录'}}</text>
    </view>

    <!-- 登录/注册表单 -->
    <view class="login-form">
      <view class="form-item">
        <input 
          class="form-input" 
          type="text" 
          placeholder="请输入用户名（3-50个字符）" 
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="50"
        />
      </view>
      <view class="form-item">
        <input 
          class="form-input" 
          type="password" 
          placeholder="请输入密码（至少6个字符）" 
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="50"
        />
      </view>
      
      <!-- 注册时显示额外字段 -->
      <view class="form-item" wx:if="{{isRegister}}">
        <input 
          class="form-input" 
          type="password" 
          placeholder="请确认密码" 
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="50"
        />
      </view>
      <view class="form-item" wx:if="{{isRegister}}">
        <input 
          class="form-input" 
          type="text" 
          placeholder="手机号（可选）" 
          value="{{mobile}}"
          bindinput="onMobileInput"
          maxlength="20"
        />
      </view>
      <view class="form-item" wx:if="{{isRegister}}">
        <input 
          class="form-input" 
          type="text" 
          placeholder="昵称（可选）" 
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="50"
        />
      </view>

      <button 
        class="login-btn primary-btn"
        bindtap="{{isRegister ? 'onRegister' : 'onPasswordLogin'}}"
        loading="{{loading}}"
        disabled="{{loading}}">
        <text class="btn-icon">{{isRegister ? '✨' : '🔐'}}</text>
        <text>{{isRegister ? '注册' : '登录'}}</text>
      </button>

      <!-- 切换登录/注册 -->
      <view class="switch-mode" bindtap="toggleMode">
        <text class="switch-text">{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
      </view>
    </view>

    <!-- 一键登录按钮（暂时隐藏） -->
    <view class="login-buttons" style="display: none;">
      <button 
        class="login-btn primary-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        loading="{{loading}}"
        disabled="{{loading}}">
        <text class="btn-icon">📱</text>
        <text>微信手机号一键登录</text>
      </button>

      <view class="cancel-login" bindtap="handleCancel">
        <text>暂不登录，先逛逛</text>
      </view>
    </view>

    <view class="login-tips">
      <text class="tip-text">登录即表示同意</text>
      <text class="link-text">《用户协议》</text>
      <text class="tip-text">和</text>
      <text class="link-text">《隐私政策》</text>
    </view>
  </view>
</view>