<view class="page" wx:if="{{device}}">
  <view class="header">
    <view class="name">{{device.name}}</view>
    <view class="status {{isOnline ? 'online' : 'offline'}}">{{isOnline ? '在线' : '离线'}}</view>
  </view>

  <view class="meta">设备编号：{{device.deviceCode || '-'}}</view>
  <view class="meta">安装位置：{{device.location || '-'}}</view>

  <view class="player-box">
    <video
      wx:if="{{isOnline && canPlay}}"
      id="monitor-video"
      class="player"
      src="{{device.streamUrl}}"
      autoplay
      controls
      muted
      object-fit="contain"
      bindplay="onVideoPlay"
      bindwaiting="onVideoWaiting"
      bindloadedmetadata="onVideoLoaded"
      binderror="onVideoError"
    />

    <view wx:if="{{!isOnline}}" class="offline-box">
      <text class="offline-text">设备离线</text>
      <text class="offline-sub">当前监控不在线，请稍后查看</text>
    </view>

    <view wx:if="{{isOnline && !canPlay}}" class="offline-box">
      <text class="offline-text">等待播放</text>
      <text class="offline-sub">{{errorMessage || '点击下方按钮开始播放'}}</text>
    </view>

    <view wx:if="{{loading}}" class="loading-mask">加载中...</view>
  </view>

  <view class="actions" wx:if="{{isOnline}}">
    <button class="btn" bindtap="onManualRetry">刷新</button>
  </view>

  <view class="hint">
    性能优化说明：仅在本页面创建视频组件，离开页面自动停止，降低卡顿概率。
  </view>
</view>

