<view class="page">
  <view class="header">
    <view class="title">养殖户监控总览</view>
    <view class="sub-title">请选择养殖户查看监控列表</view>
  </view>

  <view class="search-box">
    <input
      class="search-input"
      placeholder="搜索养殖户昵称/账号/手机号"
      value="{{keyword}}"
      bindinput="onKeywordInput"
    />
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="list" wx:if="{{!loading}}">
    <view
      wx:for="{{filteredBreeders}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      data-name="{{item.nickname || item.username || ('养殖户' + item.id)}}"
      bindtap="goToBreeder"
    >
      <view class="card-main">
        <view class="name">{{item.nickname || item.username || ('养殖户' + item.id)}}</view>
        <view class="mobile">{{item.mobile || '未绑定手机号'}}</view>
      </view>
      <view class="card-side">
        <view class="count">监控 {{item.monitor_count}}</view>
        <view class="arrow">></view>
      </view>
    </view>

    <view class="empty" wx:if="{{filteredBreeders.length === 0}}">
      暂无可查看的养殖户
    </view>
  </view>
</view>
