.page {
  min-height: 100vh;
  background: #f4f7f9;
  padding: 24rpx;
}

.header {
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d2b24;
}

.sub-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7e76;
}

.search-box {
  margin-bottom: 18rpx;
}

.search-input {
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  border: 1px solid #dde8e3;
}

.loading,
.empty {
  margin-top: 80rpx;
  text-align: center;
  color: #8a9992;
  font-size: 26rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid #dce8e2;
  box-shadow: 0 4rpx 18rpx rgba(16, 48, 32, 0.06);
}

.card:active {
  transform: scale(0.99);
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e2e27;
}

.mobile {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #73867d;
}

.card-side {
  text-align: right;
}

.count {
  font-size: 24rpx;
  color: #2f6f58;
}

.arrow {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #9db0a7;
}
