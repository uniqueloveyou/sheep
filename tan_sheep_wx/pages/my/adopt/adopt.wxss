page {
  background-color: #f7f8fa;
  padding-bottom: 180rpx;
}

.container {
  padding: 24rpx;
}

/* ===== 分区标题 ===== */
.section-header {
  display: flex;
  align-items: center;
  margin: 20rpx 4rpx 20rpx;
}
.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.dot-green { background-color: #4CAF50; }
.dot-gray  { background-color: #aaa; }
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}
.section-hint {
  font-size: 22rpx;
  color: #aaa;
}
.section-count {
  font-size: 22rpx;
  color: #aaa;
  background: #f0f0f0;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 6rpx;
}

/* ===== 折叠区域标题 ===== */
.other-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-top: 30rpx;
  margin-bottom: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.other-header-left {
  display: flex;
  align-items: center;
}
.collapse-arrow {
  transition: transform 0.25s;
}
.arrow-up {
  transform: rotate(180deg);
}

/* ===== 历史记录小卡片 ===== */
.other-list {
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}
.other-card {
  display: flex;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f7f7f7;
  align-items: center;
}
.other-card:last-child { border-bottom: none; }
.other-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.other-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.other-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #555;
}
.other-detail-row {
  display: flex;
  align-items: center;
}
.order-no-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ===== 状态小徽章（认养中绿色胶囊）===== */
.status-dot-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: bold;
}
.badge-green {
  background-color: #e8f5e9;
  color: #2e7d32;
}

/* ===== 页面标题 ===== */
.page-title {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.title-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.count-text {
  font-size: 24rpx;
  color: #999;
}

.trace-summary-banner {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 0 10rpx 24rpx;
  padding: 18rpx 22rpx;
  background: #fff7f0;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(195, 105, 38, 0.06);
}

.trace-summary-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.trace-summary-text {
  font-size: 24rpx;
  color: #7f4d27;
}

.trace-summary-subtext {
  font-size: 22rpx;
  color: #a06f48;
}

/* ===== 状态页面 ===== */
.loading-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.spin-icon {
  margin-bottom: 20rpx;
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-state text {
  color: #999;
  font-size: 28rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-adopt-button {
  background-color: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 70rpx;
  line-height: 66rpx;
  font-size: 28rpx;
}

/* ===== 订单状态徽章 ===== */
.order-status-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: bold;
  white-space: nowrap;
}
.status-paid,
.status-adopting {
  background-color: #e8f5e9;
  color: #2e7d32;
}
.status-settlement {
  background-color: #fff3e0;
  color: #b35a00;
}
.status-awaiting {
  background-color: #e8f4ff;
  color: #1268a8;
}
.status-shipping {
  background-color: #e3f2fd;
  color: #1565c0;
}
.status-completed {
  background-color: #f0f1f3;
  color: #60646c;
}
.status-cancelled {
  background-color: #f4f4f4;
  color: #999;
}
.status-default {
  background-color: #f5f5f5;
  color: #757575;
}

/* ===== 羊只卡片列表 ===== */
.sheep-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.sheep-card {
  display: flex;
  flex-direction: column;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 22rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
  transition: all 0.2s ease;
}

.sheep-card:active {
  transform: scale(0.98);
  background-color: #f9f9f9;
}

.card-main-row {
  display: flex;
  align-items: flex-start;
}

.sheep-media {
  width: 132rpx !important;
  max-width: 132rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.sheep-avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  display: block;
}

.sheep-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.sheep-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.sheep-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.25;
  flex: 1;
}

.identity-line {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #4d5966;
  line-height: 1.35;
}

.ear-tag-line {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9a9a9a;
  line-height: 1.35;
  word-break: break-all;
}

.card-lower {
  margin-top: 24rpx;
  padding-left: 0;
}

.trace-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 34rpx;
}

.trace-line-new {
  color: #c24a2f;
}

.trace-line-text {
  font-size: 23rpx;
  color: #7f858c;
  line-height: 1.35;
}

.trace-line-new .trace-line-text {
  color: #c24a2f;
}

.trace-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #c6ccd2;
  flex-shrink: 0;
}

.trace-dot-new {
  background-color: #ff6b57;
  box-shadow: 0 0 0 8rpx rgba(255, 107, 87, 0.12);
}

.history-trace-line {
  margin-top: 4rpx;
}

.sheep-details {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: auto;
}

.detail-text {
  font-size: 22rpx;
  color: #999;
}

.detail-divider {
  font-size: 20rpx;
  color: #eee;
  margin: 0 10rpx;
}

.adoption-fee-row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 22rpx;
  color: #8a6d3b;
}

.care-row {
  margin-top: 12rpx;
}

.care-summary {
  font-size: 22rpx;
  color: #8a8f96;
  line-height: 1.45;
}

.adoption-action-row {
  width: 132rpx;
  margin-top: 10rpx;
  text-align: center;
}

button.adoption-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  width: 112rpx !important;
  min-width: 0 !important;
  max-width: 112rpx;
  height: 40rpx;
  line-height: 38rpx;
  border-radius: 20rpx;
  font-size: 18rpx;
  color: #16831c;
  background: #f0faf1;
  border: 1rpx solid #bfe8c4;
  box-sizing: border-box;
  white-space: nowrap;
}

button.adoption-action-btn::after {
  border: none;
}

button.adoption-action-btn.primary {
  color: #fff;
  background: #16831c;
  border-color: #16831c;
}

button.adoption-action-btn.secondary {
  color: #1268a8;
  background: #eef7ff;
  border-color: #cfe7fa;
}

button.adoption-action-btn.disabled {
  color: #8a8f96;
  background: #f3f4f5;
  border-color: #edf0f2;
}

/* ===== 申请交付弹窗 ===== */
.delivery-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 100000;
  background: rgba(0, 0, 0, 0.48);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.delivery-modal {
  width: 100%;
  max-height: 82vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 32rpx calc(22rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.delivery-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.delivery-modal-title {
  font-size: 34rpx;
  color: #222;
  font-weight: 700;
}

.delivery-modal-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 44rpx;
  color: #999;
}

.delivery-modal-body {
  max-height: 55vh;
  flex: 1;
}

.delivery-fee-panel {
  background: #f7fbf7;
  border: 1rpx solid #dcefe0;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 24rpx;
}

.delivery-fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 25rpx;
  color: #5e6872;
  line-height: 1.6;
}

.delivery-fee-row.strong {
  margin-top: 6rpx;
  font-size: 29rpx;
  color: #16831c;
  font-weight: 700;
}

.delivery-fee-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8a8f96;
  line-height: 1.5;
}

.delivery-form {
  border-top: 1rpx solid #f2f3f5;
}

.delivery-field {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f2f3f5;
}

.delivery-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #555;
}

.delivery-input,
.delivery-picker-value,
.delivery-textarea {
  flex: 1;
  font-size: 26rpx;
  color: #222;
}

.delivery-picker-value.placeholder {
  color: #b6bcc4;
}

.address-field {
  align-items: flex-start;
  padding: 24rpx 0;
}

.delivery-textarea {
  min-height: 80rpx;
  line-height: 1.5;
}

.delivery-modal-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-top: 4rpx;
  background: #fff;
}

.delivery-cancel-btn,
.delivery-submit-btn {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  margin: 0;
}

.delivery-cancel-btn {
  color: #555;
  background: #f4f5f7;
}

.delivery-submit-btn {
  color: #fff;
  background: #16831c;
}

.delivery-cancel-btn::after,
.delivery-submit-btn::after {
  border: none;
}
