<view class="container">

  <view class="page-title">
    <text class="title-text">我的羊只</text>
    <text class="count-text" wx:if="{{adoptingList.length > 0}}">认养中 {{adoptingList.length}} 只</text>
  </view>

  <view wx:if="{{traceUnreadCount > 0}}" class="trace-summary-banner">
    <van-icon name="volume-o" size="16px" color="#c4551e" />
    <view class="trace-summary-copy">
      <text class="trace-summary-text">你有 {{traceUnreadCount}} 只羊收到了新的溯源动态</text>
      <text class="trace-summary-subtext">点开对应卡片，可直接查看本次新增记录</text>
    </view>
  </view>

  <block wx:if="{{loading}}">
    <view class="loading-state">
      <van-icon name="flower-o" size="30px" color="#ccc" class="spin-icon"/>
      <text>正在获取数据...</text>
    </view>
  </block>

  <block wx:elif="{{adoptingList.length === 0 && otherList.length === 0}}">
    <view class="empty-state">
      <image class="empty-image" src="/images/icons/function/f1.png" mode="aspectFit"></image>
      <text class="empty-title">暂无已领养的羊</text>
      <text class="empty-hint">在购物车中结算后，你的羊就会出现在这里</text>
      <button class="go-adopt-button" bindtap="goHome">去领养</button>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{adoptingList.length > 0}}">
      <view class="section-header">
        <view class="section-dot dot-green"></view>
        <text class="section-title">认养中</text>
        <text class="section-hint">羊只正在农场被照料</text>
      </view>
      <view class="sheep-list">
        <view
          wx:for="{{adoptingList}}"
          wx:key="id"
          class="sheep-card"
          bindtap="viewAdoptionEntry"
          data-record-id="{{item.id}}"
          data-sheep-id="{{item.sheep.id}}"
          data-latest-trace-date="{{item.latestTraceDate}}"
        >
          <view class="card-main-row">
            <view class="sheep-media">
              <image class="sheep-avatar" src="{{item.sheep.image || '/images/icons/function/f1.png'}}" mode="aspectFill"></image>
              <view class="adoption-action-row">
                <button
                  wx:if="{{item.canRequestEnd}}"
                  class="adoption-action-btn"
                  catchtap="requestEndAdoption"
                  data-order-id="{{item.order_id}}"
                  data-adoption-days="{{item.adoption_days}}"
                  data-daily-fee-text="{{item.dailyCareFeeText}}"
                  data-estimated-fee-text="{{item.estimatedCareFeeText}}">
                  申请交付
                </button>
                <button
                  wx:elif="{{item.canPayCareFee}}"
                  class="adoption-action-btn primary"
                  catchtap="payCareFee"
                  data-order-id="{{item.order_id}}"
                  data-care-fee-text="{{item.careFeeAmountText}}">
                  支付服务费
                </button>
                <button
                  wx:else
                  class="adoption-action-btn {{item.actionDisabled ? 'disabled' : 'secondary'}}"
                  disabled="{{item.actionDisabled}}">
                  {{item.actionText}}
                </button>
              </view>
            </view>
            <view class="sheep-info">
              <view class="sheep-header">
                <text class="sheep-name">滩羊 #{{item.sheep.id}}</text>
                <view class="order-status-badge {{item.statusClass}}">{{item.order_status}}</view>
              </view>
              <text class="identity-line">{{item.identityText || '基础档案待完善'}}</text>
              <text class="ear-tag-line">耳标 {{item.sheep.ear_tag || '未设置'}}</text>

              <view class="card-lower">
                <view class="trace-line {{item.hasNewTrace ? 'trace-line-new' : ''}}">
                  <view class="trace-dot {{item.hasNewTrace ? 'trace-dot-new' : ''}}"></view>
                  <text class="trace-line-text">{{item.hasNewTrace ? item.traceHintText : item.traceSummaryText}}</text>
                </view>

                <view class="care-row">
                  <text class="care-summary">{{item.careSummaryText}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{otherList.length > 0}}">
      <view class="other-section-header" bindtap="toggleOther">
        <view class="other-header-left">
          <view class="section-dot dot-gray"></view>
          <text class="section-title">历史记录</text>
          <text class="section-count">{{otherList.length}} 只</text>
        </view>
        <view class="collapse-arrow {{otherExpanded ? 'arrow-up' : 'arrow-down'}}">
          <van-icon name="arrow-down" size="28rpx" color="#999"/>
        </view>
      </view>

      <view class="other-list" wx:if="{{otherExpanded}}">
        <view
          wx:for="{{otherList}}"
          wx:key="id"
          class="other-card"
          bindtap="viewAdoptionEntry"
          data-record-id="{{item.id}}"
          data-sheep-id="{{item.sheep.id}}"
          data-latest-trace-date="{{item.latestTraceDate}}"
        >
          <image class="other-avatar" src="{{item.sheep.image || '/images/icons/function/f1.png'}}" mode="aspectFill"></image>
          <view class="other-info">
            <view class="sheep-header">
              <text class="other-name">滩羊 #{{item.sheep.id}}</text>
              <view class="order-status-badge {{item.statusClass}}">{{item.order_status}}</view>
            </view>
            <view wx:if="{{item.hasNewTrace}}" class="trace-line trace-line-new history-trace-line">
              <view class="trace-dot trace-dot-new"></view>
              <text class="trace-line-text">{{item.traceHintText || '有新的溯源动态'}}</text>
            </view>
            <view class="other-detail-row">
              <text class="detail-text">耳标: {{item.sheep.ear_tag || '未设置'}}</text>
              <text class="detail-divider">|</text>
              <text class="detail-text">{{item.sheep.weight}} kg</text>
            </view>
            <text class="order-no-text">订单: {{item.order_no}}</text>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view wx:if="{{showDeliveryModal}}" class="delivery-modal-mask" catchtap="closeDeliveryModal">
    <view class="delivery-modal" catchtap="stopModalTap">
      <view class="delivery-modal-header">
        <text class="delivery-modal-title">申请交付</text>
        <text class="delivery-modal-close" catchtap="closeDeliveryModal">×</text>
      </view>

      <scroll-view class="delivery-modal-body" scroll-y>
        <view class="delivery-fee-panel">
          <view class="delivery-fee-row">
            <text>已认养</text>
            <text>{{deliveryForm.adoptionDays}} 天</text>
          </view>
          <view class="delivery-fee-row">
            <text>基础照料费</text>
            <text>¥{{deliveryForm.dailyFeeText}}/天/只</text>
          </view>
          <view class="delivery-fee-row strong">
            <text>预计需结算</text>
            <text>¥{{deliveryForm.estimatedFeeText}}</text>
          </view>
          <text class="delivery-fee-tip">提交后将停止继续计费，支付服务费后由养殖户安排物流发货。</text>
        </view>

        <view class="delivery-form">
          <view class="delivery-field">
            <text class="delivery-label">收货人</text>
            <input class="delivery-input" placeholder="请输入姓名" value="{{deliveryForm.receiverName}}" bindinput="onDeliveryNameInput" />
          </view>
          <view class="delivery-field">
            <text class="delivery-label">手机号</text>
            <input class="delivery-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{deliveryForm.receiverPhone}}" bindinput="onDeliveryPhoneInput" />
          </view>
          <picker mode="region" value="{{deliveryForm.region}}" bindchange="onDeliveryRegionChange">
            <view class="delivery-field">
              <text class="delivery-label">省市区</text>
              <text class="delivery-picker-value {{deliveryForm.region.length ? '' : 'placeholder'}}">
                {{deliveryForm.region.length ? deliveryForm.region[0] + ' ' + deliveryForm.region[1] + ' ' + deliveryForm.region[2] : '请选择省市区'}}
              </text>
              <van-icon name="arrow" size="26rpx" color="#bbb" />
            </view>
          </picker>
          <view class="delivery-field address-field">
            <text class="delivery-label">详细地址</text>
            <textarea class="delivery-textarea" placeholder="街道、门牌号等详细信息" value="{{deliveryForm.detailAddress}}" bindinput="onDeliveryAddressInput" auto-height />
          </view>
        </view>
      </scroll-view>

      <view class="delivery-modal-actions">
        <button class="delivery-cancel-btn" catchtap="closeDeliveryModal">取消</button>
        <button class="delivery-submit-btn" loading="{{deliverySubmitting}}" catchtap="submitDeliveryApplication">确认申请</button>
      </view>
    </view>
  </view>
</view>
