page {
  background-color: #f7f8fa;
  padding-bottom: 200rpx;
}

.container {
  padding: 0;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 50vh;
  color: #999;
  font-size: 28rpx;
}
.spin-icon {
  margin-bottom: 20rpx;
  animation: rotate 2s linear infinite;
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 头部卡片 */
.header-card {
  position: relative;
  padding: 40rpx 32rpx;
  background: #fff;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 30rpx;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(135deg, #FF9B44, #FF5700);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  z-index: 0;
}

.sheep-profile {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,87,0,0.1);
}

.sheep-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: #f5f5f5;
  border: 4rpx solid #fff;
}

.profile-info {
  flex: 1;
}

.sheep-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.id-tag {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.id-tag van-icon {
  margin-right: 6rpx;
}

.status-badge {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  background: #e6f6eb;
  color: #2b9939;
  font-size: 22rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 4rpx solid #fff;
}

/* 基础数据面板 */
.data-panel {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: 0 32rpx 40rpx;
  padding: 32rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.data-val {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.data-unit {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
  margin-left: 4rpx;
}

.data-label {
  font-size: 24rpx;
  color: #999;
}

/* 列表容器 */
.section {
  margin: 0 32rpx 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title van-icon {
  margin-right: 12rpx;
}

.section-count {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

.trace-overview-card {
  background: #fffaf6;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(37, 29, 17, 0.04);
}

.trace-overview-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.trace-overview-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.trace-overview-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.trace-overview-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7d6856;
}

.trace-overview-date {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  color: #b06a27;
}

.trace-stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.trace-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 110rpx;
  background: rgba(255, 255, 255, 0.78);
  border-radius: 18rpx;
}

.trace-stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff7b00;
}

.trace-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a7a6a;
}

.trace-dynamic-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.trace-dynamic-item {
  padding: 22rpx 0;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid rgba(125, 104, 86, 0.12);
}

.trace-dynamic-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.trace-dynamic-main {
  display: flex;
  flex-direction: column;
}

.trace-dynamic-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.trace-type-tag {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.trace-type-growth {
  background: #edf8ec;
  color: #2e7d32;
}

.trace-type-feeding {
  background: #fff2e8;
  color: #d6651d;
}

.trace-type-vaccination {
  background: #eaf3ff;
  color: #1565c0;
}

.trace-dynamic-date {
  font-size: 22rpx;
  color: #999;
}

.trace-dynamic-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.trace-dynamic-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666;
}

.trace-dynamic-extra {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.trace-dynamic-empty {
  margin-top: 24rpx;
  padding: 28rpx 0 8rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.trace-timeline {
  margin-top: 26rpx;
}

.trace-timeline-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.trace-timeline-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #3b3128;
}

.trace-timeline-count {
  font-size: 22rpx;
  color: #9a8774;
}

.trace-timeline-item {
  position: relative;
  display: flex;
  align-items: stretch;
}

.trace-timeline-axis {
  position: relative;
  width: 34rpx;
  flex-shrink: 0;
}

.trace-timeline-dot {
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  margin-top: 18rpx;
  border-radius: 50%;
  border: 6rpx solid #fffaf6;
  box-shadow: 0 0 0 2rpx rgba(255, 123, 0, 0.18);
}

.trace-dot-growth {
  background: #2e7d32;
}

.trace-dot-feeding {
  background: #d6651d;
}

.trace-dot-vaccination {
  background: #1565c0;
}

.trace-timeline-line {
  position: absolute;
  left: 14rpx;
  top: 44rpx;
  bottom: 0;
  width: 2rpx;
  background: rgba(125, 104, 86, 0.16);
}

.trace-timeline-content {
  flex: 1;
  min-width: 0;
  padding: 0 0 26rpx 14rpx;
}

.trace-timeline-new {
  padding-left: 18rpx;
  border-left: 6rpx solid rgba(255, 107, 87, 0.32);
}

.trace-timeline-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.trace-timeline-tags {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.trace-timeline-toggle {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  margin-top: 4rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #b06a27;
  font-size: 24rpx;
}

.trace-timeline-toggle::after {
  border: none;
}

.custom-cell-group {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02) !important;
  border-radius: 16rpx !important;
  overflow: hidden;
}

/* 身份标识（二维码） */
.qr-code-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.qr-code-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.qr-code-hint {
  font-size: 24rpx;
  color: #999;
}

/* 时间轴 (疫苗记录) */
.vaccine-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 32rpx 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.empty-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 30rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  bottom: 0;
  width: 2rpx;
  background-color: #eee;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 10rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background-color: #1989fa;
  border: 4rpx solid #e8f3fe;
}

.timeline-content {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 12rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.timeline-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.v-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.v-date {
  font-size: 24rpx;
  color: #999;
}

.v-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.record-new-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #ff6b57;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  line-height: 1;
}

.inline-new-badge {
  margin-left: 12rpx;
}

.is-new-record {
  background: #fff6ee;
  box-shadow: inset 6rpx 0 0 rgba(255, 167, 85, 0.45);
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.growth-head,
.growth-row {
  display: flex;
  align-items: center;
}

.growth-head {
  padding-bottom: 18rpx;
  margin-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.growth-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f6f6f6;
}

.growth-row:last-child {
  border-bottom: none;
}

.growth-col {
  flex: 1;
  font-size: 23rpx;
  color: #666;
  text-align: center;
}

.growth-head .growth-col {
  color: #999;
  font-size: 22rpx;
}

.growth-col.date {
  flex: 1.4;
  text-align: left;
}

.growth-date-cell {
  flex: 1.4;
  display: flex;
  align-items: center;
}

.growth-date-cell .growth-col.date {
  flex: none;
}

.growth-row-new {
  background: #fff6ee;
  border-radius: 12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.feeding-card {
  padding-top: 10rpx;
  padding-bottom: 10rpx;
}

.feeding-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f6f6f6;
}

.feeding-item:last-child {
  border-bottom: none;
}

.record-pagination {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.page-btn {
  min-width: 128rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #1a8f2a;
  color: #fff;
  font-size: 24rpx;
}

.page-btn[disabled] {
  background: #e5e5e5;
  color: #aaa;
}

.page-info {
  min-width: 96rpx;
  text-align: center;
  color: #666;
  font-size: 24rpx;
}

.feeding-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 20rpx;
}

.feeding-type {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.feeding-date {
  font-size: 22rpx;
  color: #999;
}

.feeding-amount {
  font-size: 24rpx;
  color: #666;
}

/* 底部操作区 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  margin: 0 12rpx;
}

.outline-btn {
  background: #fff;
  color: #FF5700;
  border: 2rpx solid #FF5700;
}

.primary-btn {
  background: linear-gradient(90deg, #FF7B00, #FF5700);
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255,87,0,0.3);
}
