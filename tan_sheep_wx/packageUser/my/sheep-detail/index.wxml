<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <van-icon name="flower-o" size="30px" color="#ccc" class="spin-icon"/>
    <text>拼命加载中...</text>
  </view>

  <block wx:if="{{!loading && sheepDetail}}">
    <!-- 头部信息卡片 -->
    <view class="header-card">
      <view class="card-bg"></view>
      <view class="sheep-profile">
        <image class="sheep-avatar" src="{{sheepDetail.image || '/images/icons/function/f1.png'}}" mode="aspectFill" bindtap="previewSheepImage"></image>
        <view class="profile-info">
          <text class="sheep-title">我的滩羊 #{{sheepDetail.id}}</text>
          <view class="id-tag"><van-icon name="label-o"/> {{sheepDetail.ear_tag}}</view>
        </view>
        <view class="status-badge">{{sheepDetail.status}}</view>
      </view>
    </view>

    <!-- 基础数据面板 -->
    <view class="data-panel">
      <view class="data-item">
        <text class="data-val">{{sheepDetail.weight}}<text class="data-unit">kg</text></text>
        <text class="data-label">体重</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{sheepDetail.height}}<text class="data-unit">cm</text></text>
        <text class="data-label">体高</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{sheepDetail.length}}<text class="data-unit">cm</text></text>
        <text class="data-label">体长</text>
      </view>
    </view>

    <!-- 溯源动态摘要 -->
    <view class="section">
      <view class="section-title"><van-icon name="underway-o" color="#ff7b00"/> 溯源动态</view>
      <view class="trace-overview-card">
        <view class="trace-overview-head">
          <view class="trace-overview-copy">
            <text class="trace-overview-title">{{newTraceCount > 0 ? '新的溯源动态' : '最近溯源动态'}}</text>
            <text class="trace-overview-desc">{{traceSummaryText}}</text>
          </view>
          <view wx:if="{{latestTraceDate}}" class="trace-overview-date">{{latestTraceDate}}</view>
        </view>
        <view class="trace-stat-grid">
          <view class="trace-stat-item">
            <text class="trace-stat-value">{{traceStats.growth}}</text>
            <text class="trace-stat-label">生长</text>
          </view>
          <view class="trace-stat-item">
            <text class="trace-stat-value">{{traceStats.feeding}}</text>
            <text class="trace-stat-label">喂养</text>
          </view>
          <view class="trace-stat-item">
            <text class="trace-stat-value">{{traceStats.vaccines}}</text>
            <text class="trace-stat-label">疫苗</text>
          </view>
          <view class="trace-stat-item">
            <text class="trace-stat-value">{{traceStats.total}}</text>
            <text class="trace-stat-label">总记录</text>
          </view>
        </view>
        <view wx:if="{{traceTimelinePreview.length > 0}}" class="trace-timeline">
          <view class="trace-timeline-heading">
            <text class="trace-timeline-title">完整溯源时间线</text>
            <text class="trace-timeline-count">{{traceTimelineItems.length}}条</text>
          </view>
          <view class="trace-timeline-item" wx:for="{{traceTimelinePreview}}" wx:key="id">
            <view class="trace-timeline-axis">
              <view class="trace-timeline-dot trace-dot-{{item.type}}"></view>
              <view wx:if="{{index < traceTimelinePreview.length - 1}}" class="trace-timeline-line"></view>
            </view>
            <view class="trace-timeline-content {{item.isNew ? 'trace-timeline-new' : ''}}">
              <view class="trace-timeline-meta">
                <view class="trace-timeline-tags">
                  <text class="trace-type-tag trace-type-{{item.type}}">{{item.typeLabel}}</text>
                  <text wx:if="{{item.isNew}}" class="record-new-badge">新</text>
                </view>
                <text class="trace-dynamic-date">{{item.date}}</text>
              </view>
              <text class="trace-dynamic-name">{{item.title}}</text>
              <text class="trace-dynamic-summary">{{item.summary}}</text>
              <text class="trace-dynamic-extra">{{item.meta}}</text>
            </view>
          </view>
          <button
            wx:if="{{traceTimelineCanToggle}}"
            class="trace-timeline-toggle"
            bindtap="toggleTraceTimeline"
          >{{traceTimelineExpanded ? '收起时间线' : '查看全部记录'}}</button>
        </view>
        <view wx:else class="trace-dynamic-empty">
          <text>当前还没有溯源记录，后续养殖记录会在这里按时间汇总</text>
        </view>
      </view>
    </view>

    <!-- 详细档案页签 -->
    <view class="section">
      <view class="section-title"><van-icon name="notes-o" color="#4CAF50"/> 电子档案</view>
      <van-cell-group inset custom-class="custom-cell-group">
        <van-cell title="性别" value="{{sheepDetail.gender}}" />
        <van-cell title="出生日期" value="{{sheepDetail.birth_date}}" />
        <van-cell title="羊龄" value="{{sheepDetail.age_display}}" />
        <van-cell 
          title="负责农户" 
          value="{{sheepDetail.breeder_name}}" 
          icon="contact" 
          is-link 
          bind:click="viewBreederDetail"
          data-id="{{sheepDetail.owner_id}}"
        />
      </van-cell-group>
    </view>

    <!-- 溯源二维码（只有在存在时显示） -->
    <view class="section" wx:if="{{sheepDetail.qr_code}}">
      <view class="section-title"><van-icon name="scan" color="#1989fa"/> 身份标识</view>
      <view class="qr-code-box">
        <image class="qr-code-img" src="{{sheepDetail.qr_code}}" mode="aspectFit" bindtap="previewQRCode"></image>
        <text class="qr-code-hint">点击可放大，扫码验证羊只身份信息</text>
      </view>
    </view>

    <!-- 疫苗与健康 -->
    <view class="section">
      <view class="section-title"><van-icon name="shield-o" color="#1989fa"/> 检疫与健康</view>
      <view class="vaccine-list" wx:if="{{vaccineRecords.length > 0}}">
        <view class="timeline-item" wx:for="{{pagedVaccineRecords}}" wx:key="id">
          <view class="timeline-dot"></view>
          <view class="timeline-content {{item.isNew ? 'is-new-record' : ''}}">
            <view class="timeline-header">
              <view class="timeline-title-row">
                <text class="v-type">{{item.vaccineType}}</text>
                <text wx:if="{{item.isNew}}" class="record-new-badge">新</text>
              </view>
              <text class="v-date">{{item.displayDate}}</text>
            </view>
            <text class="v-desc">操作人: {{item.administeredBy || '未记录'}} | 剂量: {{item.dosageText}}</text>
            <text wx:if="{{item.expiryDate}}" class="v-desc">有效期至: {{item.expiryDate}}</text>
            <text wx:if="{{item.notes}}" class="v-desc">{{item.notes}}</text>
          </view>
        </view>
        <view class="record-pagination" wx:if="{{vaccineTotalPages > 1}}">
          <button class="page-btn" bindtap="changeRecordPage" data-type="vaccine" data-direction="-1" disabled="{{vaccinePage <= 1}}">上一页</button>
          <text class="page-info">{{vaccinePage}} / {{vaccineTotalPages}}</text>
          <button class="page-btn" bindtap="changeRecordPage" data-type="vaccine" data-direction="1" disabled="{{vaccinePage >= vaccineTotalPages}}">下一页</button>
        </view>
      </view>
      <view class="empty-list" wx:else>
        <text>该羊只暂无接种记录</text>
      </view>
    </view>

    <!-- 生长记录 -->
    <view class="section">
      <view class="section-title">
        <van-icon name="chart-trending-o" color="#ff8a00"/> 生长记录
        <text class="section-count" wx:if="{{growthRecords.length > 0}}">{{growthRecords.length}}条</text>
      </view>
      <view class="record-card" wx:if="{{growthRecords.length > 0}}">
        <view class="growth-head">
          <text class="growth-col date">日期</text>
          <text class="growth-col">体重</text>
          <text class="growth-col">体高</text>
          <text class="growth-col">体长</text>
        </view>
        <view class="growth-row {{item.isNew ? 'growth-row-new' : ''}}" wx:for="{{pagedGrowthRecords}}" wx:key="id">
          <view class="growth-date-cell">
            <text class="growth-col date">{{item.recordDate}}</text>
            <text wx:if="{{item.isNew}}" class="record-new-badge inline-new-badge">新</text>
          </view>
          <text class="growth-col">{{item.weightText}}</text>
          <text class="growth-col">{{item.heightText}}</text>
          <text class="growth-col">{{item.lengthText}}</text>
        </view>
        <view class="record-pagination" wx:if="{{growthTotalPages > 1}}">
          <button class="page-btn" bindtap="changeRecordPage" data-type="growth" data-direction="-1" disabled="{{growthPage <= 1}}">上一页</button>
          <text class="page-info">{{growthPage}} / {{growthTotalPages}}</text>
          <button class="page-btn" bindtap="changeRecordPage" data-type="growth" data-direction="1" disabled="{{growthPage >= growthTotalPages}}">下一页</button>
        </view>
      </view>
      <view class="empty-list" wx:else>
        <text>该羊只暂无生长记录</text>
      </view>
    </view>

    <!-- 喂养记录 -->
    <view class="section">
      <view class="section-title">
        <van-icon name="fire-o" color="#ff976a"/> 喂养记录
        <text class="section-count" wx:if="{{feedingRecords.length > 0}}">{{feedingRecords.length}}条</text>
      </view>
      <view class="record-card feeding-card" wx:if="{{feedingRecords.length > 0}}">
        <view class="feeding-item {{item.isNew ? 'is-new-record' : ''}}" wx:for="{{pagedFeedingRecords}}" wx:key="id">
          <view class="feeding-top">
            <view class="timeline-title-row">
              <text class="feeding-type">{{item.feedType}}</text>
              <text wx:if="{{item.isNew}}" class="record-new-badge">新</text>
            </view>
            <text class="feeding-date">{{item.feedDate}}</text>
          </view>
          <text class="feeding-amount">投喂量：{{item.amountText}}</text>
        </view>
        <view class="record-pagination" wx:if="{{feedingTotalPages > 1}}">
          <button class="page-btn" bindtap="changeRecordPage" data-type="feeding" data-direction="-1" disabled="{{feedingPage <= 1}}">上一页</button>
          <text class="page-info">{{feedingPage}} / {{feedingTotalPages}}</text>
          <button class="page-btn" bindtap="changeRecordPage" data-type="feeding" data-direction="1" disabled="{{feedingPage >= feedingTotalPages}}">下一页</button>
        </view>
      </view>
      <view class="empty-list" wx:else>
        <text>该羊只暂无喂养记录</text>
      </view>
    </view>

    <!-- 底部操作区 -->
    <view class="action-bar">
      <button class="action-btn primary-btn" bindtap="viewMonitor">查看监控</button>
    </view>
  </block>
</view>
