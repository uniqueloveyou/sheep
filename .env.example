# Django 基础配置
# 生产环境建议 DJANGO_DEBUG=False，DJANGO_ALLOWED_HOSTS 填服务器域名或 IP
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sheep.youzilite.app,127.0.0.1,localhost

# 数据库选择：1=本地数据库，0=云数据库
USE_LOCAL_DB=0

# 本地 MySQL 配置
LOCAL_DB_NAME=sheep_xdb
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=change-me
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306

# 云端 MySQL 配置
DB_NAME=sheep_xdb
DB_USER=change-me
DB_PASSWORD=change-me
DB_HOST=change-me
DB_PORT=3306
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=600

# 微信小程序配置
WX_APP_ID=change-me
WX_APP_SECRET=change-me

# DeepSeek 智能问答配置
DEEPSEEK_API_KEY=change-me
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
MOCK_DEEPSEEK=False

# Cloudflare R2 图床配置
R2_ACCOUNT_ID=change-me
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me
R2_BUCKET_NAME=change-me
R2_PUBLIC_URL=https://your-r2-public-domain.example
